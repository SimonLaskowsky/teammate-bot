# Which platform to run: "slack" or "teams"
PLATFORM=slack

# Encryption key for storing integration tokens securely in Supabase
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-key

# --- SLACK (required when PLATFORM=slack) ---
# Get these from https://api.slack.com/apps → your app
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-level-token

# --- TEAMS (required when PLATFORM=teams) ---
# Get these from https://dev.teams.microsoft.com → Tools → Bot management
MICROSOFT_APP_ID=your-microsoft-app-id
MICROSOFT_APP_PASSWORD=your-client-secret
PORT=3000

# --- SHARED ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

ANTHROPIC_API_KEY=sk-ant-your-key

# Comma-separated user IDs who can run "add this:" commands
# Slack: find via profile → ⋮ → Copy member ID
# Teams: set DEBUG=true, send any message, copy from.id from terminal
ADMIN_USERS=

# Set to true to log user IDs (helps find your ADMIN_USERS value)
DEBUG=false
